{
  "openapi": "3.0.0",
  "info": {
    "title": "Password Manager API",
    "description": "API documentation for the Password Manager Backend application. Includes authentication (local and Google OAuth) and password storage management.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local development server"
    },
    {
      "url": "https://passwordsbackend.vercel.app",
      "description": "Vercel production server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Provide token as: Bearer <your_jwt_token>"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "66532cb1e3df6a1f5c6a1523"
          },
          "username": {
            "type": "string",
            "example": "johndoe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Password": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "66532cb1e3df6a1f5c6a1529"
          },
          "userId": {
            "type": "string",
            "example": "66532cb1e3df6a1f5c6a1523"
          },
          "website": {
            "type": "string",
            "example": "google.com"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "securePassword123!"
          },
          "category": {
            "type": "string",
            "example": "Social Media"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserRegisterInput": {
        "type": "object",
        "required": [
          "username",
          "email",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "example": "johndoe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "password123"
          }
        }
      },
      "UserLoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "password123"
          }
        }
      },
      "GoogleAuthInput": {
        "type": "object",
        "required": [
          "email",
          "googleId"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "username": {
            "type": "string",
            "example": "John Doe"
          },
          "googleId": {
            "type": "string",
            "example": "109823746192837461234"
          }
        }
      },
      "PasswordCreateInput": {
        "type": "object",
        "required": [
          "website",
          "email",
          "password"
        ],
        "properties": {
          "website": {
            "type": "string",
            "example": "github.com"
          },
          "email": {
            "type": "string",
            "example": "john@example.com"
          },
          "password": {
            "type": "string",
            "example": "superSecretGithubPass1"
          },
          "category": {
            "type": "string",
            "example": "Work"
          }
        }
      },
      "PasswordUpdateInput": {
        "type": "object",
        "properties": {
          "website": {
            "type": "string",
            "example": "github.com"
          },
          "email": {
            "type": "string",
            "example": "john.new@example.com"
          },
          "password": {
            "type": "string",
            "example": "evenMoreSecretPass2"
          },
          "category": {
            "type": "string",
            "example": "Work & Personal"
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "User already exists or bad request"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate user & get token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid Credentials"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/auth/google": {
      "post": {
        "summary": "Authenticate with Google OAuth token",
        "description": "Authenticates user via Google OAuth data, creates a new user if the email does not exist yet.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleAuthInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Google authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/auth/profile": {
      "get": {
        "summary": "Get authenticated user profile details",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile successfully fetched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Authorization denied/Token is invalid"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/passwords": {
      "get": {
        "summary": "Get all passwords belonging to the authenticated user",
        "tags": [
          "Passwords"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of passwords",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Password"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authorization denied/Token is invalid"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "summary": "Create a new password entry",
        "tags": [
          "Passwords"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordCreateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password entry successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Password"
                }
              }
            }
          },
          "401": {
            "description": "Authorization denied/Token is invalid"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/api/passwords/{id}": {
      "put": {
        "summary": "Update an existing password entry by ID",
        "tags": [
          "Passwords"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique ID of the password entry",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordUpdateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password entry successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Password"
                }
              }
            }
          },
          "401": {
            "description": "Not authorized to edit this resource"
          },
          "404": {
            "description": "Password entry not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "delete": {
        "summary": "Delete a password entry by ID",
        "tags": [
          "Passwords"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique ID of the password entry",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password entry successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Password entry removed"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not authorized to delete this resource"
          },
          "404": {
            "description": "Password entry not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  }
}
